STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=postgres://jules@localhost:5432/gorumin_medusa
DIGITAL_CODE_ENCRYPTION_KEY=change-me-use-a-long-random-secret
MEDUSA_BACKEND_URL=http://localhost:9000
STOREFRONT_URL=http://localhost:8000
# Shared with storefront — triggers ISR purge after catalog sync
REVALIDATE_SECRET=change-me-revalidate-secret

# Fazer Cards supplier (leave FAZER_API_KEY empty to disable the integration)
FAZER_API_KEY=
FAZER_BASE_URL=https://api.fzr.cards/api/v2
FAZER_BALANCE_ALERT_THRESHOLD=50
# Webhook (US-2.5): HMAC-SHA256 secret + header for POST /hooks/fazer.
# Leave empty in dev to skip signature verification.
FAZER_WEBHOOK_SECRET=
FAZER_WEBHOOK_SIGNATURE_HEADER=x-fazer-signature

# Pricing: USD->COP conversion for the catalog sync
EXCHANGE_RATE_USD_COP=4000
DEFAULT_MARGIN_PCT=15
# Optional live FX endpoint (e.g. open.er-api.com). If set, the daily price
# refresh job uses it; otherwise it falls back to EXCHANGE_RATE_USD_COP.
EXCHANGE_RATE_API_URL=
# Per-category margin overrides as JSON (category slug -> margin %).
CATEGORY_MARGINS={"gift-cards":15,"top-ups":18}
# % FX drift between runs that triggers an automatic price refresh.
RATE_CHANGE_THRESHOLD_PCT=2

# Where fulfillment-failure alerts are emailed
ADMIN_ALERT_EMAIL=admin@gorumin.com

# Brevo — transactional email (see docs/email/brevo-setup.md)
BREVO_API_KEY=
BREVO_SMTP_KEY=
BREVO_FROM_EMAIL=noreply@gorumin.com
BREVO_SENDER_NAME=rumin
BREVO_REPLY_TO=soporte@gorumin.com
# Public logo for transactional emails (upload: ./infra/gcp/sync-email-assets.sh)
EMAIL_LOGO_URL=https://storage.googleapis.com/gorumin-public-assets/email/gorumin-logo-256.png
EMAIL_VERIFICATION_LAYOUT=stripe
BREVO_TEMPLATE_ORDER_PLACED=
BREVO_TEMPLATE_EMAIL_VERIFICATION=
BREVO_TEMPLATE_DIGITAL_CODE=

# Mercado Pago (Colombia). Leave MP_ACCESS_TOKEN empty to keep the default
# payment provider. Use TEST- credentials for sandbox.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_LOCALE=es-CO
MP_NOTIFICATION_URL=http://localhost:9000/hooks/mercadopago
MP_STATEMENT_DESCRIPTOR=GORUMIN

# Wompi (Colombia). Sandbox keys from comercios.wompi.co
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_API_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_NOTIFICATION_URL=http://localhost:9000/hooks/wompi
MOCK_WOMPI=false

# Local dev mocks — simulate MP approve/reject + instant Fazer codes (see docs/dev-mocks.md)
MOCK_MP=false
MOCK_FAZER=false

# Google OAuth (RUM-69). Leave empty to keep email/password only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# Per-transaction Fazer funding via Binance (Épica 13)
FUNDING_ENABLED=false
FAZER_FUNDING_METHOD=binancepay
FUNDING_MAX_USD_PER_ORDER=500
FUNDING_PAYMENT_POLL_ATTEMPTS=20
FUNDING_PAYMENT_POLL_DELAY_MS=3000
MOCK_BINANCE=false
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_USDT_NETWORK=TRX
BINANCE_PAY_MERCHANT_ID=
BINANCE_PAY_CERTIFICATE_SN=
BINANCE_PAY_PRIVATE_KEY=
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com
