# Publishable API key for the Medusa backend. Required for the storefront to function.
# Learn how to create a publishable key: https://docs.medusajs.com/v2/resources/storefront-development/publishable-api-keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# URL of the Medusa backend API server
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Default region code to use for the storefront
NEXT_PUBLIC_DEFAULT_REGION=co

# Base URL of the storefront (used for generating absolute URLs)
NEXT_PUBLIC_BASE_URL=https://localhost:8000

# Shared with Medusa — on-demand cache purge after catalog sync
REVALIDATE_SECRET=change-me-revalidate-secret

# Google OAuth (RUM-69). Set true when Medusa has GOOGLE_* credentials.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Per-order funding UX (Épica 13 — set true when Medusa FUNDING_ENABLED=true)
NEXT_PUBLIC_FUNDING_ENABLED=false

# Stripe publishable key for payment processing (optional, only if using Stripe)
NEXT_PUBLIC_STRIPE_KEY=

# Medusa Cloud S3 bucket hostname (optional, only for Medusa Cloud deployments)
MEDUSA_CLOUD_S3_HOSTNAME=

# Medusa Cloud S3 bucket path (optional, only for Medusa Cloud deployments)
MEDUSA_CLOUD_S3_PATHNAME=

# Node environment (development, production, etc.)
NODE_ENV=development

# BFF (US-5.1/5.3): payment provider id used to initiate checkout sessions
NEXT_PUBLIC_PAYMENT_PROVIDER_ID=pp_mercadopago_mercadopago
# BFF CORS allow-list (comma-separated). Defaults to NEXT_PUBLIC_BASE_URL.
BFF_ALLOWED_ORIGINS=http://localhost:8000
# BFF rate limiting: window in ms and max requests per IP per window
BFF_RATE_LIMIT_WINDOW_MS=60000
BFF_RATE_LIMIT_MAX=120
