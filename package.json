{
  "name": "gorumin",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/arjul1989/rumingames.git"
  },
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "medusa:dev": "turbo dev --filter=@gorumin/medusa",
    "storefront:dev": "turbo dev --filter=@gorumin/storefront"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "@medusajs/eslint-plugin": "2.16.0",
    "eslint": "^9.39.4",
    "jiti": "^2.7.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  }
}
