# =============================================================================
# Gorumin — environment variables (copy to app-specific .env files)
# =============================================================================
#
# Three environments: local | sandbox (sbx.gorumin.com) | production (gorumin.com)
# Full guide: docs/infra/environments.md
#   Local:    apps/medusa/.env + apps/storefront/.env.local  (see infra/gcp/env.local.example)
#   Sandbox:  infra/gcp/.env.sandbox                         (see infra/gcp/env.sandbox.example)
#   Prod:     infra/gcp/.env.production                    (see infra/gcp/env.production.example)
#
# --- Medusa (apps/medusa/.env) ---
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-jwt-secret
COOKIE_SECRET=change-me-cookie-secret
DATABASE_URL=postgres://jules@localhost:5432/gorumin_medusa

# Fazer Cards (Épica 2)
FAZER_API_KEY=

# Mercado Pago Colombia (Épica 3)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Wompi Colombia (Épica 14 — pasarela alternativa)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_API_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_NOTIFICATION_URL=http://localhost:9000/hooks/wompi
WOMPI_THREE_DS_ENABLED=true
# Sandbox only: challenge_v2 | no_challenge_success | challenge_denied
WOMPI_THREE_DS_AUTH_TYPE=challenge_v2
MOCK_WOMPI=false

# ePayco Colombia (pasarela prioritaria — mejores tarifas)
EPAYCO_PUBLIC_KEY=
EPAYCO_PRIVATE_KEY=
EPAYCO_TEST_MODE=true
EPAYCO_CONFIRMATION_SECRET=
EPAYCO_NOTIFICATION_URL=http://localhost:9000/hooks/epayco
MOCK_EPAYCO=false
EPAYCO_THREE_DS_ENABLED=true
# Sandbox only: challenge | no_challenge_success | challenge_denied
EPAYCO_THREE_DS_AUTH_TYPE=challenge

# Digital code encryption (AES-256). Use a long random secret in prod.
DIGITAL_CODE_ENCRYPTION_KEY=

# URLs used for email links and redirects
MEDUSA_BACKEND_URL=http://localhost:9000
STOREFRONT_URL=http://localhost:8000
# Shared secret for POST /api/revalidate (storefront cache purge after Fazer sync)
REVALIDATE_SECRET=change-me-revalidate-secret

# Brevo — transactional email (see docs/email/brevo-setup.md)
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@gorumin.com
BREVO_SENDER_NAME=rumin
BREVO_REPLY_TO=soporte@gorumin.com
ADMIN_ALERT_EMAIL=admin@gorumin.com
# Optional Brevo dashboard template IDs (leave empty to use built-in HTML)
BREVO_TEMPLATE_ORDER_PLACED=
BREVO_TEMPLATE_EMAIL_VERIFICATION=
BREVO_TEMPLATE_DIGITAL_CODE=

# Google OAuth (RUM-69). Leave empty to keep email/password only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# Per-transaction Fazer funding via Binance (Épica 13). Set FUNDING_ENABLED=true to activate.
FUNDING_ENABLED=false
FAZER_FUNDING_METHOD=binancepay
FUNDING_MAX_USD_PER_ORDER=500
FUNDING_PAYMENT_POLL_ATTEMPTS=20
FUNDING_PAYMENT_POLL_DELAY_MS=3000
MOCK_BINANCE=false
# Binance Spot API (USDT withdraw to Fazer pay_to address)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_USDT_NETWORK=TRX
# Binance Pay merchant (alternative to Spot withdraw)
BINANCE_PAY_MERCHANT_ID=
BINANCE_PAY_CERTIFICATE_SN=
BINANCE_PAY_PRIVATE_KEY=
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com

# --- Storefront (apps/storefront/.env.local) ---
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_DEFAULT_REGION=co
NEXT_PUBLIC_BASE_URL=http://localhost:8000
# Show "Continuar con Google" when Medusa has Google OAuth configured
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
# Per-order Fazer funding UX (Épica 13 — matches Medusa FUNDING_ENABLED)
NEXT_PUBLIC_FUNDING_ENABLED=false
# Default checkout payment provider (Mercado Pago). The Brick reads its public
# key from the payment session created by Medusa, so no key is needed here.
NEXT_PUBLIC_PAYMENT_PROVIDER_ID=pp_mercadopago_mercadopago

# --- Jira seed script (scripts/seed-jira*.py — never commit tokens) ---
JIRA_EMAIL=arjul1989@gmail.com
JIRA_API_TOKEN=
