# Copy to infra/gcp/.env.sandbox (gitignored) before deploy-sandbox.sh
# Sandbox = internet-facing pre-production at sbx.gorumin.com
# Never commit this file with real values.

ENVIRONMENT=sandbox

GCP_PROJECT_ID=sims-499022
GCP_REGION=us-central1
AR_REPO=gorumin

# Cloud SQL — separate instance from production
SQL_INSTANCE=gorumin-db-sbx
DB_NAME=gorumin_medusa_sbx
DB_USER=gorumin_sbx
DB_PASSWORD=change-me

# Public URLs (after domain mapping)
STOREFRONT_BASE_URL=https://sbx.gorumin.com
MEDUSA_BACKEND_URL=https://api.sbx.gorumin.com
# Until api.sbx.gorumin.com SSL is active, use the Cloud Run *.run.app URL
STOREFRONT_BUILD_BACKEND_URL=https://gorumin-medusa-sbx-ng4djsl7qa-uc.a.run.app
STOREFRONT_SERVICE=gorumin-storefront-sbx
MEDUSA_SERVICE=gorumin-medusa-sbx

# Medusa secrets — generate NEW values (do not reuse production)
JWT_SECRET=change-me-jwt-sbx
COOKIE_SECRET=change-me-cookie-sbx
DIGITAL_CODE_ENCRYPTION_KEY=change-me-32chars-minimum-sbx

# CORS (comma-separated, no spaces)
STORE_CORS=https://sbx.gorumin.com
ADMIN_CORS=https://api.sbx.gorumin.com
AUTH_CORS=https://sbx.gorumin.com,https://api.sbx.gorumin.com

# Fazer — sandbox/test API key if available; leave empty to disable
FAZER_API_KEY=
FAZER_BASE_URL=https://api.fzr.cards/api/v2
FAZER_WEBHOOK_SECRET=
FAZER_WEBHOOK_SIGNATURE_HEADER=x-fazer-signature

# Mercado Pago — TEST credentials only
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=https://api.sbx.gorumin.com/hooks/mercadopago
MP_CALLBACK_URL=https://sbx.gorumin.com/co/checkout/pending

# Wompi — sandbox keys (pub_test_ / prv_test_)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_API_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_NOTIFICATION_URL=https://api.sbx.gorumin.com/hooks/wompi
WOMPI_THREE_DS_ENABLED=true
WOMPI_THREE_DS_AUTH_TYPE=challenge_v2
MOCK_WOMPI=false

# ePayco — test mode
EPAYCO_PUBLIC_KEY=
EPAYCO_PRIVATE_KEY=
EPAYCO_TEST_MODE=true
EPAYCO_CONFIRMATION_SECRET=
EPAYCO_NOTIFICATION_URL=https://api.sbx.gorumin.com/hooks/epayco
EPAYCO_THREE_DS_ENABLED=true
EPAYCO_THREE_DS_AUTH_TYPE=challenge
MOCK_EPAYCO=false

# Brevo — use sandbox templates or a separate sender if possible
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@gorumin.com
BREVO_SENDER_NAME=Gorumin Sandbox
BREVO_REPLY_TO=soporte@gorumin.com
ADMIN_ALERT_EMAIL=admin@gorumin.com
EMAIL_LOGO_URL=https://storage.googleapis.com/gorumin-public-assets/email/gorumin-logo-256.png
EMAIL_VERIFICATION_LAYOUT=stripe

# Storefront ISR purge (unique per environment)
REVALIDATE_SECRET=

# Created in Medusa Admin after first sandbox deploy
MEDUSA_PUBLISHABLE_KEY=

# Redis — optional; use a separate Upstash database for sandbox
REDIS_URL=

# Google OAuth — register redirect for sandbox in Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://sbx.gorumin.com/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# Funding — keep disabled in sandbox unless testing Binance
FUNDING_ENABLED=false
NEXT_PUBLIC_FUNDING_ENABLED=false
