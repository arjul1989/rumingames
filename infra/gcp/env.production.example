# Copy to infra/gcp/.env.production (gitignored) before deploy-prod.sh
# Production = gorumin.com / api.gorumin.com
# Never commit this file with real values.

ENVIRONMENT=production

GCP_PROJECT_ID=sims-499022
GCP_REGION=us-central1
AR_REPO=gorumin

# Cloud SQL
SQL_INSTANCE=gorumin-db
DB_NAME=gorumin_medusa
DB_USER=gorumin
DB_PASSWORD=change-me

# Public URLs (after domain mapping)
STOREFRONT_BASE_URL=https://gorumin.com
MEDUSA_BACKEND_URL=https://api.gorumin.com
# Storefront build-time backend (use run.app until api.gorumin.com SSL is active)
STOREFRONT_BUILD_BACKEND_URL=https://gorumin-medusa-ng4djsl7qa-uc.a.run.app
STOREFRONT_SERVICE=gorumin-storefront
MEDUSA_SERVICE=gorumin-medusa

# Medusa secrets — generate strong random values for prod
JWT_SECRET=change-me-jwt
COOKIE_SECRET=change-me-cookie
DIGITAL_CODE_ENCRYPTION_KEY=change-me-32chars-minimum

# CORS (comma-separated, no spaces)
STORE_CORS=https://gorumin.com,https://www.gorumin.com
ADMIN_CORS=https://api.gorumin.com
AUTH_CORS=https://gorumin.com,https://www.gorumin.com,https://api.gorumin.com

# Integrations (optional — Medusa boots without FAZER if empty)
FAZER_API_KEY=
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=https://api.gorumin.com/hooks/mercadopago
# Buyer return URL after PSE bank transfer (defaults to STOREFRONT_URL/co/checkout/pending)
MP_CALLBACK_URL=https://gorumin.com/co/checkout/pending

# Wompi — production keys
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_API_BASE_URL=https://production.wompi.co/v1
WOMPI_NOTIFICATION_URL=https://api.gorumin.com/hooks/wompi
WOMPI_THREE_DS_ENABLED=true
MOCK_WOMPI=false

# ePayco — production keys (EPAYCO_TEST_MODE=false)
EPAYCO_PUBLIC_KEY=
EPAYCO_PRIVATE_KEY=
EPAYCO_TEST_MODE=false
EPAYCO_CONFIRMATION_SECRET=
EPAYCO_NOTIFICATION_URL=https://api.gorumin.com/hooks/epayco
EPAYCO_THREE_DS_ENABLED=true
MOCK_EPAYCO=false

# Brevo email (see docs/email/brevo-setup.md)
BREVO_API_KEY=
BREVO_SMTP_KEY=
BREVO_FROM_EMAIL=noreply@gorumin.com
BREVO_SENDER_NAME=Gorumin
BREVO_REPLY_TO=soporte@gorumin.com
ADMIN_ALERT_EMAIL=admin@gorumin.com
EMAIL_LOGO_URL=https://storage.googleapis.com/gorumin-public-assets/email/gorumin-logo-256.png
EMAIL_VERIFICATION_LAYOUT=stripe
BREVO_TEMPLATE_ORDER_PLACED=
BREVO_TEMPLATE_EMAIL_VERIFICATION=
BREVO_TEMPLATE_DIGITAL_CODE=

# Storefront cache purge after catalog/CMS sync (must match storefront REVALIDATE_SECRET)
REVALIDATE_SECRET=

# Storefront build-time (filled automatically after first Medusa seed if empty)
MEDUSA_PUBLISHABLE_KEY=

# Redis (optional — Medusa runs without Redis, but prod should use Upstash/Memorystore)
REDIS_URL=

# Google OAuth (RUM-69)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://gorumin.com/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Per-transaction Fazer funding via Binance (Épica 13)
FUNDING_ENABLED=false
FAZER_FUNDING_METHOD=binancepay
FUNDING_MAX_USD_PER_ORDER=500
FUNDING_PAYMENT_POLL_ATTEMPTS=20
FUNDING_PAYMENT_POLL_DELAY_MS=3000
MOCK_BINANCE=false
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_USDT_NETWORK=TRX
BINANCE_PAY_MERCHANT_ID=
BINANCE_PAY_CERTIFICATE_SN=
BINANCE_PAY_PRIVATE_KEY=
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com
NEXT_PUBLIC_FUNDING_ENABLED=false
