# Local development — copy values into apps/medusa/.env and apps/storefront/.env.local
# See also: /.env.example (root reference)
#
# This file documents the local environment mapping; it is NOT loaded by deploy scripts.

ENVIRONMENT=local

# URLs
MEDUSA_BACKEND_URL=http://localhost:9000
STOREFRONT_BASE_URL=http://localhost:8000
STOREFRONT_URL=http://localhost:8000

# Database (local Postgres)
DATABASE_URL=postgres://jules@localhost:5432/gorumin_medusa

# Redis (local)
REDIS_URL=redis://localhost:6379

# CORS
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

# Webhooks — use ngrok or similar if testing payment callbacks from providers
# WOMPI_NOTIFICATION_URL=https://<tunnel>.ngrok.io/hooks/wompi
# EPAYCO_NOTIFICATION_URL=https://<tunnel>.ngrok.io/hooks/epayco
# MP_NOTIFICATION_URL=https://<tunnel>.ngrok.io/hooks/mercadopago

# Payment mocks (dev only)
MOCK_MP=false
MOCK_WOMPI=false
MOCK_EPAYCO=false
MOCK_FAZER=false

# Google OAuth local
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback
